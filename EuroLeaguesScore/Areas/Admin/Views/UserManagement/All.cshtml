@model IEnumerable<AllUserViewModel>

@{
    IEnumerable<string> roles = ViewData["AllRoles"] as IEnumerable<string> 
        ?? new List<string>();
}

@section Styles {
    <link rel="stylesheet" href="~/css/team.css" asp-append-version="true" />
}

<div class="container mt-4">
    <div class="text-center mb-5">
        <h2 class="fw-bold text-white">
            <i class="bi bi-people-fill me-2 text-success"></i>User Management
        </h2>
        <p class="text-light mb-0">
            Manage registered users and their roles in EuroLeaguesScore.
        </p>
    </div>

    <div class="card team-card shadow-sm">
        <div class="card-body">
            @if (!Model.Any())
            {
                <p class="text-light mb-0 text-center">No users found.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr class="text-warning">
                                <th class="border-0">Username</th>
                                <th class="border-0">Email</th>
                                <th class="border-0">Role</th>
                                <th class="border-0 text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model)
                            {
                                <tr class="text-light">
                                    <td>@user.UserName</td>
                                    <td>@user.Email</td>

                                    <td>
                                        <form asp-area="Admin"
                                              asp-controller="UserManagement"
                                              asp-action="AssignRole"
                                              method="post"
                                              class="d-flex align-items-center gap-2">

                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="userId" value="@user.Id" />

                                            <select name="role" class="form-select form-select-sm">
                                                @foreach (var role in roles)
                                                {
                                                    <option value="@role" selected="@(role == user.Role ? "selected" : null)">
                                                        @role
                                                    </option>
                                                }
                                            </select>

                                            <button type="submit" class="btn btn-sm btn-success">
                                                Save
                                            </button>
                                        </form>

                                        <div class="small text-secondary mt-1">
                                            Current role: @user.Role
                                        </div>
                                    </td>

                                    <td class="text-center">
                                        <form asp-area="Admin"
                                              asp-controller="UserManagement"
                                              asp-action="Delete"
                                              method="post"
                                              class="d-inline">

                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@user.Id" />

                                            <button type="submit"
                                                    class="btn btn-sm btn-danger"
                                                    onclick="return confirm('Are you sure you want to delete this user?');">
                                                <i class="bi bi-trash-fill me-1"></i>Delete
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>