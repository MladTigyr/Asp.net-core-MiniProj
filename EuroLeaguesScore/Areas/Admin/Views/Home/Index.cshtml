@{
    ViewData["Title"] = "Admin Dashboard";
}

@section Styles {
    <link rel="stylesheet" href="~/css/team.css" asp-append-version="true" />
}

<div class="text-center mb-5">
    <h2 class="fw-bold text-white">
        <i class="bi bi-gear-fill me-2 text-success"></i>
        Admin Dashboard
    </h2>
    <p class="text-secondary">
        Control and manage the core data of your application.
    </p>
</div>

<div class="row g-4 justify-content-center">

    <div class="col-md-6 col-lg-4 d-flex">
        <div class="card team-card h-100 shadow-sm w-100">
            <div class="card-body d-flex flex-column justify-content-between">
                <div>
                    <h5 class="card-title fw-bold text-success mb-3">
                        <i class="bi bi-people-fill me-2 text-warning"></i>User Management
                    </h5>

                    <p class="mb-2 text-light">
                        View users, assign roles, and manage account access.
                    </p>

                    <p class="mb-0 text-muted">
                        Control administrator and user permissions.
                    </p>
                </div>

                <div class="mt-3">
                    <a asp-area="Admin"
                       asp-controller="UserManagement"
                       asp-action="All"
                       class="btn btn-sm btn-success w-100">
                        Manage Users
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-4 d-flex">
        <div class="card team-card h-100 shadow-sm w-100">
            <div class="card-body d-flex flex-column justify-content-between">
                <div>
                    <h5 class="card-title fw-bold text-success mb-3">
                        <i class="bi bi-shield-fill me-2 text-warning"></i>Team Management
                    </h5>

                    <p class="mb-2 text-light">
                        Add, edit, or remove football teams in the system.
                    </p>

                    <p class="mb-0 text-muted">
                        Maintain club information and team records.
                    </p>
                </div>

                <div class="mt-3">
                    <a asp-area="Admin"
                       asp-controller="TeamManagement"
                       asp-action="All"
                       class="btn btn-sm btn-success w-100">
                        Manage Teams
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-4 d-flex">
        <div class="card team-card h-100 shadow-sm w-100">
            <div class="card-body d-flex flex-column justify-content-between">
                <div>
                    <h5 class="card-title fw-bold text-success mb-3">
                        <i class="bi bi-person-fill me-2 text-warning"></i>Player Management
                    </h5>

                    <p class="mb-2 text-light">
                        Maintain player information and update squad data.
                    </p>

                    <p class="mb-0 text-muted">
                        Edit player details and football profiles.
                    </p>
                </div>

                <div class="mt-3">
                    <a asp-area="Admin"
                       asp-controller="PlayerManagement"
                       asp-action="All"
                       class="btn btn-sm btn-success w-100">
                        Manage Players
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-4 d-flex">
        <div class="card team-card h-100 shadow-sm w-100">
            <div class="card-body d-flex flex-column justify-content-between">
                <div>
                    <h5 class="card-title fw-bold text-success mb-3">
                        <i class="bi bi-person-badge-fill me-2 text-warning"></i>Manager Management
                    </h5>

                    <p class="mb-2 text-light">
                        Manage football managers and their associated information.
                    </p>

                    <p class="mb-0 text-muted">
                        Update manager records and club assignments.
                    </p>
                </div>

                <div class="mt-3">
                    <a asp-area="Admin"
                       asp-controller="ManagerManagement"
                       asp-action="All"
                       class="btn btn-sm btn-success w-100">
                        Manage Managers
                    </a>
                </div>
            </div>
        </div>
    </div>

</div>