@model IEnumerable<AllManagerViewModel>

@section Styles {
    <link rel="stylesheet" href="~/css/team.css" asp-append-version="true" />
}

<div class="container mt-4">
    <div class="text-center mb-5">
        <h2 class="fw-bold text-white">
            <i class="bi bi-person-badge-fill me-2 text-success"></i>Manager Management
        </h2>
        <p class="text-light mb-0">
            Manage football managers in EuroLeaguesScore.
        </p>
    </div>

    <div class="d-flex justify-content-end mb-3">
        <a asp-controller="Manager"
           asp-action="Add"
           asp-area=""
           class="btn btn-success fw-semibold">
            <i class="bi bi-plus-circle me-1"></i>Add Manager
        </a>
    </div>

    <div class="card team-card shadow-sm">
        <div class="card-body">
            @if (!Model.Any())
            {
                <p class="text-light mb-0 text-center">No managers found.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr class="text-warning">
                                <th class="border-0">Name</th>
                                <th class="border-0">Age</th>
                                <th class="border-0 text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var manager in Model)
                            {
                                <tr class="text-light">
                                    <td>@manager.Name</td>
                                    <td>@manager.Age</td>
                                    <td class="text-center">
                                        <a asp-controller="Manager"
                                           asp-action="Edit"
                                           asp-area=""
                                           asp-route-id="@manager.Id"
                                           class="btn btn-sm btn-warning text-dark fw-semibold me-2">
                                            <i class="bi bi-pencil-fill me-1"></i>Edit
                                        </a>

                                        <form asp-controller="Manager"
                                              asp-action="Delete"
                                              asp-area=""
                                              asp-route-id="@manager.Id"
                                              method="post"
                                              class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit"
                                                    class="btn btn-sm btn-danger"
                                                    onclick="return confirm('Are you sure you want to delete this manager?');">
                                                <i class="bi bi-trash-fill me-1"></i>Delete
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>