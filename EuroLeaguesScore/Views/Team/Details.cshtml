@model DetailsTeamInputModel

@{
    ViewData["Title"] = "Team Details";
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="card team-details-card shadow-lg border-0 mb-4">
            <div class="card-body p-4 p-md-5">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
                    <div>
                        <h2 class="fw-bold text-white mb-2">
                            <i class="bi bi-shield-fill text-success me-2"></i>@Model.Name
                        </h2>
                        <p class="mb-1 text-light">
                            <i class="bi bi-geo-alt-fill text-success me-2"></i>@Model.City, @Model.Country
                        </p>
                        <p class="mb-0 text-light-emphasis">
                            <i class="bi bi-award-fill text-warning me-2"></i>@Model.LeagueName
                        </p>
                        <p class="mb-0 text-light-emphasis">
                            <i class="bi bi-person-fill text-warning me-2"></i>@Model.ManagerName
                        </p>
                    </div>

                    <div class="mt-3 mt-md-0">
                        <a asp-action="All" class="btn btn-outline-light">
                            <i class="bi bi-arrow-left me-1"></i>Back to Teams
                        </a>
                    </div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <div class="stat-box text-center">
                            <h6 class="text-light-emphasis mb-2">Wins</h6>
                            <h3 class="text-success fw-bold mb-0">@Model.Wins</h3>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="stat-box text-center">
                            <h6 class="text-light-emphasis mb-2">Draws</h6>
                            <h3 class="text-warning fw-bold mb-0">@Model.Draws</h3>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="stat-box text-center">
                            <h6 class="text-light-emphasis mb-2">Losses</h6>
                            <h3 class="text-danger fw-bold mb-0">@Model.Losses</h3>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2 flex-wrap">
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-success">
                            <i class="bi bi-pencil-square me-1"></i>Edit Team
                        </a>

                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">
                            <i class="bi bi-trash me-1"></i>Delete Team
                        </a>
                    
                        @if (!Model.IsFavourite)
                        {
                            <form asp-controller="Favourite"
                                  asp-action="AddOrRemoveTeam"
                                  method="post"
                                  class="d-inline">
                                <input type="hidden" name="teamId" value="@Model.Id" />
                                <button type="submit" class="btn btn-outline-warning">
                                    <i class="bi bi-star me-1"></i>Add to Favourites
                                </button>
                            </form>
                        }
                        else
                        {
                            <a asp-controller="Favourite"
                               asp-action="Teams"
                               class="btn btn-warning text-dark fw-semibold">
                                <i class="bi bi-star-fill me-1"></i>View All Favourites
                            </a>
                        }
                    }
                </div>
            </div>
        </div>

        <div class="card team-details-card shadow-lg border-0">
            <div class="card-body p-4 p-md-5">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="fw-bold text-white mb-0">
                        <i class="bi bi-people-fill text-success me-2"></i>Squad
                    </h4>
                    <span class="badge squad-badge">@(Model.Players?.Count() ?? 0) player(s)</span>
                </div>

                @if (Model.Players != null && Model.Players.Any())
                {
                    <div class="table-responsive">
                        <table class="table team-players-table align-middle">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Age</th>
                                    <th>Position</th>
                                    <th>Goals</th>
                                    <th>Assists</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var player in Model.Players)
                                {
                                    <tr>
                                        <td class="fw-semibold text-white">@player.Name</td>
                                        <td>@player.Age</td>
                                        <td>@player.Position</td>
                                        <td>@player.Goals</td>
                                        <td>@player.Assists</td>
                                        <td>
                                            <a asp-controller="Player"
                                               asp-action="Details"
                                               asp-route-id="@player.Id"
                                               class="btn btn-sm btn-outline-success">
                                                <i class="bi bi-eye me-1"></i>Details
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-squad text-center py-4">
                        <i class="bi bi-person-x fs-1 text-secondary"></i>
                        <p class="text-light-emphasis mt-3 mb-0">No players have been added to this team yet.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>