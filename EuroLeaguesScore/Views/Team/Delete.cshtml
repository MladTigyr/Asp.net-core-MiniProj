@model DeleteTeamViewModel

@{
    ViewData["Title"] = "Delete Team";
}

@section Styles {
    <link rel="stylesheet" href="~/css/team.css" asp-append-version="true" />
}

<div class="row justify-content-center">
    <div class="col-lg-7 col-md-9">
        <div class="card team-form-card shadow-lg border-0">
            <div class="card-body p-4 p-md-5 text-center">

                <h2 class="fw-bold text-danger mb-3">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    Delete Team
                </h2>

                <p class="text-light-emphasis mb-4">
                    Are you sure you want to delete this team?
                </p>

                <div class="alert alert-danger">
                    This action cannot be undone.
                </div>

                <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                    <input asp-for="Id" type="hidden" />

                    <div class="d-flex gap-2 justify-content-center mt-4">
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash me-1"></i>Delete
                        </button>

                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-light">
                            Cancel
                        </a>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>