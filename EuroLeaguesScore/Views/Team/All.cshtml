@model IEnumerable<AllTeamViewModel>

@{
    ViewData["Title"] = "All Teams";
}

<h2 class="mb-4 fw-bold text-white">
    <i class="bi bi-shield-fill me-2 text-success"></i>All Teams
</h2>

<div class="d-flex justify-content-between align-items-center mb-4">
    <a asp-controller="Favourite"
       asp-action="Teams"
       class="btn btn-warning text-dark fw-semibold">
        <i class="bi bi-star-fill me-1"></i>
        View All Favourites
    </a>
    <a asp-action="Add" class="btn btn-success">
        + Add Team
    </a>
</div>

<div class="row g-4">

    @foreach (var team in Model)
    {
        <div class="col-md-4 col-lg-3">
            <div class="card team-card h-100 shadow-sm">
                <div class="card-body d-flex flex-column justify-content-between">

                    <div>
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title fw-bold text-success mb-0">
                                @team.Name
                            </h5>

                            @if (User.Identity?.IsAuthenticated ?? false)
                            {
                                <form asp-controller="Favourite"
                                      asp-action="ToggleTeam"
                                      method="post"
                                      class="ms-2">
                                    <input type="hidden" name="teamId" value="@team.Id" />

                                    <button type="submit"
                                            class="btn p-0 border-0 bg-transparent shadow-none"
                                            title="Toggle favourite">
                                        @if (team.IsFavourite)
                                        {
                                            <i class="bi bi-star-fill text-warning fs-5"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-star text-light-emphasis fs-5"></i>
                                        }
                                    </button>
                                </form>
                            }
                        </div>

                        <p class="mb-1 text-light">
                            <i class="bi bi-geo-alt-fill text-success"></i>
                            @team.City, @team.Country
                        </p>

                        <p class="mb-2 text-muted">
                            <i class="bi bi-award-fill text-warning"></i>
                            @team.LeagueName
                        </p>

                        <p class="mb-2 text-muted">
                            <i class="bi bi-person-fill text-warning"></i>
                            @(string.IsNullOrWhiteSpace(team.ManagerName) ? "No manager" : team.ManagerName)
                        </p>
                    </div>

                    <div class="mt-3">
                        <div class="d-flex justify-content-between small text-light mb-2">
                            <span>W: @team.Wins</span>
                            <span>D: @team.Draws</span>
                            <span>L: @team.Losses</span>
                        </div>

                        <a asp-controller="Team"
                           asp-action="Details"
                           asp-route-id="@team.Id"
                           class="btn btn-sm btn-success w-100">
                            View Team
                        </a>
                    </div>

                </div>
            </div>
        </div>
    }

</div>