@model EditTeamInputModel

@{
    ViewData["Title"] = "Edit Team";
}

@section Styles {
    <link rel="stylesheet" href="~/css/team.css" asp-append-version="true" />
}

<div class="row justify-content-center">
    <div class="col-lg-7 col-md-9">
        <div class="card team-form-card shadow-lg border-0">
            <div class="card-body p-4 p-md-5">
                <div class="text-center mb-4">
                    <h2 class="fw-bold text-white mb-2">
                        <i class="bi bi-plus-circle-fill text-success me-2"></i>Edit Team
                    </h2>
                    <p class="text-light-emphasis mb-0">
                        Edit a football team in EuroLeaguesScore
                    </p>
                </div>

                <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                    <input asp-for="Id" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Name" class="form-control team-input" placeholder="Team Name" />
                        <label asp-for="Name">Team Name</label>
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Country" class="form-control team-input" placeholder="Country" />
                        <label asp-for="Country">Country</label>
                        <span asp-validation-for="Country" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="City" class="form-control team-input" placeholder="City" />
                        <label asp-for="City">City</label>
                        <span asp-validation-for="City" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-light">Manager</label>

                        <select asp-for="ManagerId" class="form-select team-input">
                            <option value="">Choose manager</option>

                            @foreach (var manager in Model.Managers)
                            {
                                <option value="@manager.Id">@manager.Name</option>
                            }
                        </select>

                        <span asp-validation-for="ManagerId" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <select asp-for="@Model.LeagueId" class="form-select team-input">
                            <option value="">Choose League</option>

                            @foreach (var league in Model.Leagues)
                            {
                                <option value="@league.Id">@league.Name</option>
                            }
                        </select>
                        <span asp-validation-for="@Model.LeagueId" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-floating mb-3">
                                <input asp-for="Wins" class="form-control team-input" placeholder="Wins" />
                                <label asp-for="Wins">Wins</label>
                                <span asp-validation-for="Wins" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="form-floating mb-3">
                                <input asp-for="Draws" class="form-control team-input" placeholder="Draws" />
                                <label asp-for="Draws">Draws</label>
                                <span asp-validation-for="Draws" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="form-floating mb-3">
                                <input asp-for="Losses" class="form-control team-input" placeholder="Losses" />
                                <label asp-for="Losses">Losses</label>
                                <span asp-validation-for="Losses" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-success flex-fill">
                            <i class="bi bi-check-circle me-1"></i>Edit Team
                        </button>

                        <a asp-action="All" class="btn btn-outline-light flex-fill">
                            <i class="bi bi-arrow-left me-1"></i>Back to Teams
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
