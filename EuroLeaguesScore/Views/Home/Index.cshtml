﻿@{
ViewData["Title"] = "Welcome";
}

<div class="text-center mt-5">

    <h1 class="display-4">Welcome to the best football application</h1>

    <p class="lead mt-3">
        A simple application for tracking Europe's biggest football leagues.
    </p>

    <hr class="my-4" />

    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <p>
            Welcome back! Ready to be the best manager in the world?
        </p>

        <div class="mt-4">
            <a asp-controller="Team"
               asp-action="All"
               class="btn btn-success btn-lg">
                View All Teams
            </a>
        </div>
    }
    else
    {
        <p>
            Please login or register to continue.
        </p>

        <div class="mt-4">

            <a asp-area="Identity"
               asp-page="/Account/Login"
               class="btn btn-primary btn-lg me-3">
                Login
            </a>

            <a asp-area="Identity"
               asp-page="/Account/Register"
               class="btn btn-outline-primary btn-lg">
                Register
            </a>

        </div>
    }
</div>