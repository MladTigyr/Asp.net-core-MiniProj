<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EuroLeaguesScore</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EuroLeaguesScore.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
</head>
<body class="football-body">
    <header>
        <nav class="navbar navbar-expand-lg football-navbar shadow-sm">
            <div class="container">
                <a class="navbar-brand football-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-trophy-fill me-2"></i>EuroLeaguesScore
                </a>

                <button class="navbar-toggler football-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link football-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item">
                                <a class="nav-link football-link" asp-area="" asp-controller="Team" asp-action="All">
                                    <i class="bi bi-shield-fill me-1"></i>Teams
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link football-link" asp-area="" asp-controller="Player" asp-action="All">
                                    <i class="bi bi-person-fill me-1"></i>Players
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link football-link" asp-area="" asp-controller="League" asp-action="All">
                                    <i class="bi bi-award-fill me-1"></i>Leagues
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link football-link" asp-area="" asp-controller="Manager" asp-action="All">
                                    <i class="bi bi-person-fill me-1"></i>Managers
                                </a>
                            </li>
                        }
                    </ul>

                    <div class="d-flex align-items-center">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="football-hero">
        <div class="container">
            <div class="hero-content text-center text-white">
                <h1 class="display-6 fw-bold mb-2">Track Europe’s Biggest Football Leagues</h1>
                <p class="mb-0">Teams, players, results and your own football universe.</p>
            </div>
        </div>
    </div>

    <main class="container football-main-content">
        @RenderBody()
    </main>

    <footer class="football-footer mt-5">
        <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center py-3">
            <span>© 2026 EuroLeaguesScore</span>
            <a asp-area="" asp-controller="Home" asp-action="Privacy" class="football-footer-link">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>