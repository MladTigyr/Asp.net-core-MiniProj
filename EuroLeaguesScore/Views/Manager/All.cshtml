@model IEnumerable<AllManagerViewModel>

@{
    ViewData["Title"] = "All Managers";
}

@section Styles {
    <link rel="stylesheet" href="~/css/team.css" asp-append-version="true" />
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <h2 class="fw-bold text-white mb-1">
            <i class="bi bi-clipboard2-pulse-fill text-success me-2"></i>All Managers
        </h2>
        <p class="text-light-emphasis mb-0">Browse all managers across your football world</p>
    </div>

    @if (User.Identity?.IsAuthenticated ?? false)
    {
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Add" class="btn btn-success">
                <i class="bi bi-plus-circle me-1"></i>Add Manager
            </a>
        }
    }
</div>

<div class="card team-details-card manager-table-card shadow-lg border-0">
    @await Html.PartialAsync("_SearchBlock", new SearchBlockViewModel
    {
        Controller = "Manager",
        Action = "All",
        SearchTerm = Context.Request.Query["searchTerm"],
        Placeholder = "Search managers..."
    })

    <div class="card-body p-4">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table team-players-table align-middle manager-table">
                    <thead>
                        <tr>
                            <th>Manager</th>
                            <th>Age</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var manager in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="manager-avatar-sm">
                                            @manager.Name.Substring(0, 1).ToUpper()
                                        </div>
                                        <div>
                                            <div class="fw-semibold text-white">@manager.Name</div>
                                            <div class="text-light-emphasis small">Head Coach</div>
                                        </div>
                                    </div>
                                </td>
                                <td>@manager.Age</td>
                                <td>
                                    <div class="d-flex gap-2 justify-content-end flex-wrap">
                                        <a asp-action="Details"
                                           asp-route-id="@manager.Id"
                                           class="btn btn-sm btn-outline-success">
                                            <i class="bi bi-eye me-1"></i>Details
                                        </a>

                                        @if (User.Identity?.IsAuthenticated ?? false)
                                        {
                                            @if (User.IsInRole("Admin"))
                                            {
                                                <a asp-action="Edit"
                                                   asp-route-id="@manager.Id"
                                                   class="btn btn-sm btn-success">
                                                    <i class="bi bi-pencil-square me-1"></i>Edit
                                                </a>

                                                <a asp-action="Delete"
                                                   asp-route-id="@manager.Id"
                                                   class="btn btn-sm btn-outline-danger">
                                                    <i class="bi bi-trash me-1"></i>Delete
                                                </a>
                                            }
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-squad text-center py-5">
                <i class="bi bi-person-workspace fs-1 text-secondary"></i>
                <p class="text-light-emphasis mt-3 mb-3">No managers have been added yet.</p>
                @if (User.Identity?.IsAuthenticated ?? false)
                {
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Add" class="btn btn-success">
                            <i class="bi bi-plus-circle me-1"></i>Add First Manager
                        </a>
                    }
                }
            </div>
        }
    </div>
</div>
