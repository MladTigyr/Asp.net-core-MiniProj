@model DetailsManagerViewModel

@{
    ViewData["Title"] = "Manager Details";
}

<div class="row justify-content-center">
    <div class="col-lg-9">
        <div class="card team-details-card manager-details-card shadow-lg border-0 overflow-hidden">
            <div class="manager-details-header"></div>
            <div class="card-body p-4 p-md-5">

                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="manager-avatar-lg">
                            @Model.Name.Substring(0, 1).ToUpper()
                        </div>

                        <div>
                            <h2 class="fw-bold text-white mb-2">
                                <i class="bi bi-person-badge-fill text-success me-2"></i>@Model.Name
                            </h2>
                            <p class="mb-1 text-light">
                                <i class="bi bi-calendar-event text-success me-2"></i>Age: @Model.Age
                            </p>
                            <p class="mb-1 text-light-emphasis">
                                <i class="bi bi-briefcase-fill text-warning me-2"></i>Role: Manager
                            </p>
                            <p class="mb-0 text-light-emphasis">
                                <i class="bi bi-shield-fill text-success me-2"></i>
                                Team:
                                @if (!string.IsNullOrWhiteSpace(Model.TeamName))
                                {
                                    <span class="text-white">@Model.TeamName</span>
                                }
                                else
                                {
                                    <span>Unassigned</span>
                                }
                            </p>
                        </div>
                    </div>

                    <div>
                        <a asp-action="All" class="btn btn-outline-light">
                            <i class="bi bi-arrow-left me-1"></i>Back to Managers
                        </a>
                    </div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <div class="stat-box text-center h-100">
                            <h6 class="text-light-emphasis mb-2">Age</h6>
                            <h3 class="text-success fw-bold mb-0">@Model.Age</h3>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="stat-box text-center h-100">
                            <h6 class="text-light-emphasis mb-2">Current Team</h6>
                            <h5 class="text-white fw-semibold mb-0">@(string.IsNullOrWhiteSpace(Model.TeamName) ? "Free Agent" : Model.TeamName)</h5>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="stat-box text-center h-100">
                            <h6 class="text-light-emphasis mb-2">League</h6>
                            <h5 class="text-warning fw-semibold mb-0">@(string.IsNullOrWhiteSpace(Model.LeagueName) ? "-" : Model.LeagueName)</h5>
                        </div>
                    </div>
                </div>

                <div class="manager-highlight-box mb-4">
                    <h5 class="text-white mb-2">
                        <i class="bi bi-stars text-warning me-2"></i>Manager Snapshot
                    </h5>
                    <p class="text-light-emphasis mb-0">
                        @Model.Name is @(Model.TeamName == null ? "currently available for a new challenge." : $"leading {Model.TeamName} in {(string.IsNullOrWhiteSpace(Model.LeagueName) ? "the competition" : Model.LeagueName)}.")
                    </p>
                </div>

                <div class="d-flex gap-2 flex-wrap">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-success">
                        <i class="bi bi-pencil-square me-1"></i>Edit Manager
                    </a>

                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">
                        <i class="bi bi-trash me-1"></i>Delete Manager
                    </a>
                </div>

            </div>
        </div>
    </div>
</div>
