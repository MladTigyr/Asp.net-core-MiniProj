@model AddManagerInputModel

@{
    ViewData["Title"] = "Add Manager";
}

@section Styles {
    <link rel="stylesheet" href="~/css/team.css" asp-append-version="true" />
}

<div class="row justify-content-center">
    <div class="col-lg-7 col-md-9">
        <div class="card team-form-card manager-form-card shadow-lg border-0">
            <div class="card-body p-4 p-md-5">

                <div class="text-center mb-4">
                    <h2 class="fw-bold text-white mb-2">
                        <i class="bi bi-person-workspace text-success me-2"></i>Add Manager
                    </h2>
                    <p class="text-light-emphasis mb-0">
                        Create a new manager profile and assign a team
                    </p>
                </div>

                <form asp-action="Add" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Name" class="form-control team-input" placeholder="Name" />
                        <label asp-for="Name">Manager Name</label>
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Age" class="form-control team-input" placeholder="Age" />
                        <label asp-for="Age">Age</label>
                        <span asp-validation-for="Age" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-light">Team</label>
                        <select asp-for="TeamId" class="form-select team-input">
                            <option value="">Choose team</option>
                            @foreach (var team in Model.TeamNames)
                            {
                                <option value="@team.Id">@team.Name</option>
                            }
                        </select>
                        <span asp-validation-for="TeamId" class="text-danger"></span>
                    </div>

                    <div class="manager-tip-box mb-3">
                        <i class="bi bi-lightbulb-fill text-warning me-2"></i>
                        A manager can be created without a team if you want to assign them later.
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-success flex-fill">
                            <i class="bi bi-check-circle me-1"></i>Add Manager
                        </button>

                        <a asp-action="All" class="btn btn-outline-light flex-fill">
                            <i class="bi bi-arrow-left me-1"></i>Back to Managers
                        </a>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
