@model IEnumerable<FavouritePlayerViewModel>

@{
    ViewData["Title"] = "My Favourite Players";
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
    <div>
        <h2 class="fw-bold text-white mb-1">
            <i class="bi bi-star-fill text-warning me-2"></i>My Favourite Players
        </h2>
        <p class="text-light-emphasis mb-0">
            Players you’ve added to your favourites.
        </p>
    </div>
    <div class="mt-3 mt-md-0">
        <a asp-controller="Player" asp-action="All" class="btn btn-outline-light">
            <i class="bi bi-arrow-left me-1"></i>Back to All Players
        </a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="card team-form-card shadow-lg border-0">
        <div class="card-body p-5 text-center">
            <i class="bi bi-star text-warning fs-1 mb-3"></i>
            <h4 class="text-white fw-bold mb-2">No Favourite Players</h4>
            <p class="text-light-emphasis mb-0">
                You haven’t added any players to your favourites yet.
            </p>
        </div>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var player in Model)
        {
            <div class="col-md-6 col-xl-4">
                <div class="card team-details-card shadow-lg border-0 h-100 overflow-hidden">

                    <div style="height: 6px; background: linear-gradient(90deg, #22c55e, #16a34a);"></div>

                    <div class="card-body d-flex flex-column p-4">

                        <!-- Top row: Country + Star -->
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span></span>
                            <!-- Filled star -->
                            <i class="bi bi-star-fill text-warning fs-5"></i>
                        </div>

                        <!-- name -->
                        <h4 class="fw-bold text-white mb-2">
                            <a asp-controller="Player"
                               asp-action="Details"
                               asp-route-id="@player.Id"
                               class="fw-semibold text-white text-decoration-none">
                                @player.Name
                            </a>
                        </h4>

                        <p class="text-light-emphasis mb-4">
                            <i class="bi bi-date-fill text-warning me-2"></i>@player.Age
                        </p>

                        <!-- Actions -->
                        <div class="mt-auto d-flex gap-2 flex-wrap">

                            <!-- Details -->
                            <a asp-controller="Player"
                               asp-action="Details"
                               asp-route-id="@player.Id"
                               class="btn btn-outline-light flex-grow-1">
                                <i class="bi bi-eye me-1"></i>Details
                            </a>

                            <!-- Remove favourite -->
                            <form asp-controller="Favourite"
                                  asp-action="AddOrRemovePlayer"
                                  method="post"
                                  class="flex-grow-1">

                                <input type="hidden" name="playerId" value="@player.Id" />

                                <button type="submit" class="btn btn-outline-danger w-100">
                                    <i class="bi bi-star-fill me-1"></i>Remove
                                </button>
                            </form>

                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}